# =============================================================================
# Zero to SRE — .gitignore
# =============================================================================

# --- Terraform ---
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
secrets/
credentials/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
*.egg
.pytest_cache/
.mypy_cache/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker ---
docker-compose.override.yml

# --- Kubernetes ---
kubeconfig
*.kubeconfig

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
